---
import BaseLayout from "../layouts/BaseLayout.astro";
import SearchableShelf from "../components/SearchableShelf.svelte";
import library from "../data/library.js";

const newStuff = library.users
  .flatMap((user) => [
    ...user.books.map((book) => ({
      title: book.title,
      subtitle: [book.author, book.year ? `(${book.year})` : null].filter(Boolean).join(" "),
      imageUrl: book.cover_url,
      imageAlt: `Cover of ${book.title}`,
      addedAt: book.added_at,
      username: user.username,
      meta: `Added by ${user.username} on ${book.added_at}`,
      href: `/users/${user.username}/`,
      placeholderLabel: "No cover",
      kindLabel: "Book"
    })),
    ...user.music.map((artist) => ({
      title: artist.name,
      subtitle: [artist.genre, artist.country ? `(${artist.country})` : null].filter(Boolean).join(" "),
      imageUrl: artist.image_url,
      imageAlt: `Artist image for ${artist.name}`,
      wide: true,
      addedAt: artist.added_at,
      username: user.username,
      meta: `Added by ${user.username} on ${artist.added_at}`,
      href: `/users/${user.username}/`,
      placeholderLabel: "No image",
      kindLabel: "Music"
    })),
    ...user.movies.map((movie) => ({
      title: movie.title,
      subtitle: movie.year ? `(${movie.year})` : "",
      imageUrl: movie.poster_url,
      imageAlt: `Poster for ${movie.title}`,
      isPosterFallback: true,
      posterText: movie.year ? `(${movie.year})` : "",
      addedAt: movie.added_at,
      username: user.username,
      meta: `Added by ${user.username} on ${movie.added_at}`,
      href: `/users/${user.username}/`,
      kindLabel: "Movie"
    }))
  ])
  .sort((a, b) => b.addedAt.localeCompare(a.addedAt));
---

<BaseLayout title="Server Library">
  <section class="stats-grid">
    <article>
      <h3><a href="/users/">Users</a></h3>
      <p>{library.totals.users}</p>
    </article>
    <article>
      <h3><a href="/books/">Books</a></h3>
      <p>{library.totals.books}</p>
    </article>
    <article>
      <h3><a href="/music/">Music</a></h3>
      <p>{library.totals.music}</p>
    </article>
    <article>
      <h3><a href="/movies/">Movies</a></h3>
      <p>{library.totals.movies}</p>
    </article>
  </section>

  <section class="category">
    <h2>New stuff</h2>
    <SearchableShelf
      client:load
      items={newStuff}
      placeholder="Search recent additions"
      searchLabel="Search new stuff"
      emptyMessage="No saved items are stored in the database yet."
    />
  </section>

</BaseLayout>
