---
import BaseLayout from "../layouts/BaseLayout.astro";
import SearchableShelf from "../components/SearchableShelf.svelte";
import library from "../data/library.js";

const bookPicks = library.users.flatMap((user) =>
  user.books.map((book) => ({
    title: book.title,
    imageUrl: book.cover_url,
    imageAlt: `Cover of ${book.title}`
  }))
);

const musicPicks = library.users.flatMap((user) =>
  user.music.map((artist) => ({
    title: artist.name,
    imageUrl: artist.image_url,
    imageAlt: `Artist image for ${artist.name}`,
    wide: true
  }))
);

const moviePicks = library.users.flatMap((user) =>
  user.movies.map((movie) => ({
    title: movie.title,
    imageUrl: movie.poster_url,
    imageAlt: `Poster for ${movie.title}`,
    year: movie.year
  }))
);

const newStuff = library.users
  .flatMap((user) => [
    ...user.books.map((book) => ({
      title: book.title,
      subtitle: [book.author, book.year ? `(${book.year})` : null].filter(Boolean).join(" "),
      imageUrl: book.cover_url,
      imageAlt: `Cover of ${book.title}`,
      addedAt: book.added_at,
      username: user.username,
      meta: `Added by ${user.username} on ${book.added_at}`,
      href: `/users/${user.username}/`,
      placeholderLabel: "No cover",
      kindLabel: "Book",
      avatarText: user.username.slice(0, 1).toUpperCase()
    })),
    ...user.music.map((artist) => ({
      title: artist.name,
      subtitle: [artist.genre, artist.country ? `(${artist.country})` : null].filter(Boolean).join(" "),
      imageUrl: artist.image_url,
      imageAlt: `Artist image for ${artist.name}`,
      wide: true,
      addedAt: artist.added_at,
      username: user.username,
      meta: `Added by ${user.username} on ${artist.added_at}`,
      href: `/users/${user.username}/`,
      placeholderLabel: "No image",
      kindLabel: "Music",
      avatarText: user.username.slice(0, 1).toUpperCase()
    })),
    ...user.movies.map((movie) => ({
      title: movie.title,
      subtitle: movie.year ? `(${movie.year})` : "",
      imageUrl: movie.poster_url,
      imageAlt: `Poster for ${movie.title}`,
      isPosterFallback: true,
      posterText: movie.year ? `(${movie.year})` : "",
      addedAt: movie.added_at,
      username: user.username,
      meta: `Added by ${user.username} on ${movie.added_at}`,
      href: `/users/${user.username}/`,
      kindLabel: "Movie",
      avatarText: user.username.slice(0, 1).toUpperCase()
    }))
  ])
  .sort((a, b) => b.addedAt.localeCompare(a.addedAt));
---

<BaseLayout title="Server Library">
  <section class="category">
    <h2>About this library</h2>
    <p>
      Welcome to the library. This page will be a hub for everyones interests in Vimothy's Vestibule. Currently have APIs for 
      books, movies and music. Data will be added either manually (through mnemos bot and a /library command) or it will be 
      done automaically with a bit of NLP and some help from 1984-bot. 
    </p>
  </section>

  <section class="stats-grid">
    <article>
      <h3><a href="/users/">Users</a></h3>
      <p>{library.totals.users}</p>
    </article>
    <article>
      <h3><a href="/books/">Books</a></h3>
      <p>{library.totals.books}</p>
    </article>
    <article>
      <h3><a href="/music/">Music</a></h3>
      <p>{library.totals.music}</p>
    </article>
    <article>
      <h3><a href="/movies/">Movies</a></h3>
      <p>{library.totals.movies}</p>
    </article>
  </section>

  <section class="category">
    <h2>Shelves</h2>

    <div class="scroll-shelf">
      <div class="shelf-head">
        <p class="eyebrow">Books</p>
        <div class="shelf-controls">
          <button class="shelf-button" type="button" data-shelf-prev="books" aria-label="Scroll books left">←</button>
          <button class="shelf-button" type="button" data-shelf-next="books" aria-label="Scroll books right">→</button>
        </div>
      </div>
      <div class="scroll-window" data-shelf="books">
        <div class="scroll-track">
          {bookPicks.map((book) => (
            <div class="scroll-card">
              {book.imageUrl ? (
                <img class="scroll-art" src={book.imageUrl} alt={book.imageAlt} loading="lazy" />
              ) : (
                <div class="scroll-art scroll-art-placeholder" aria-hidden="true">Book</div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="scroll-shelf">
      <div class="shelf-head">
        <p class="eyebrow">Movies</p>
        <div class="shelf-controls">
          <button class="shelf-button" type="button" data-shelf-prev="movies" aria-label="Scroll movies left">←</button>
          <button class="shelf-button" type="button" data-shelf-next="movies" aria-label="Scroll movies right">→</button>
        </div>
      </div>
      <div class="scroll-window" data-shelf="movies">
        <div class="scroll-track">
          {moviePicks.map((movie) => (
            <div class="scroll-card">
              {movie.imageUrl && !movie.imageUrl.startsWith("data:image/svg+xml") ? (
                <img class="scroll-art" src={movie.imageUrl} alt={movie.imageAlt} loading="lazy" />
              ) : (
                <div class="scroll-art scroll-art-placeholder" aria-hidden="true">
                  {movie.title}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="scroll-shelf">
      <div class="shelf-head">
        <p class="eyebrow">Music</p>
        <div class="shelf-controls">
          <button class="shelf-button" type="button" data-shelf-prev="music" aria-label="Scroll music left">←</button>
          <button class="shelf-button" type="button" data-shelf-next="music" aria-label="Scroll music right">→</button>
        </div>
      </div>
      <div class="scroll-window" data-shelf="music">
        <div class="scroll-track">
          {musicPicks.map((artist) => (
            <div class="scroll-card scroll-card-wide">
              {artist.imageUrl ? (
                <img class="scroll-art scroll-art-wide" src={artist.imageUrl} alt={artist.imageAlt} loading="lazy" />
              ) : (
                <div class="scroll-art scroll-art-wide scroll-art-placeholder" aria-hidden="true">
                  {artist.title}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="category">
    <h2>Recently added</h2>
    <SearchableShelf
      client:load
      items={newStuff}
      placeholder="Search recent additions"
      searchLabel="Search recently added"
      emptyMessage="No saved items are stored in the database yet."
    />
  </section>

</BaseLayout>

<script is:inline>
  const shelfStep = 320;

  for (const button of document.querySelectorAll("[data-shelf-prev], [data-shelf-next]")) {
    button.addEventListener("click", () => {
      const name = button.getAttribute("data-shelf-prev") || button.getAttribute("data-shelf-next");
      const shelf = document.querySelector(`[data-shelf="${name}"]`);
      if (!shelf) return;

      const direction = button.hasAttribute("data-shelf-prev") ? -1 : 1;
      shelf.scrollBy({ left: direction * shelfStep, behavior: "smooth" });
    });
  }
</script>
